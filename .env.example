# Copy to .env (docker compose reads it automatically). All values are OPTIONAL.
#
# The system reproduces EVERY reported figure with none of these set — the
# narrative layer is the only thing that uses the LLM, and it falls back to a
# deterministic mock when no key is present. Numbers never depend on the LLM.

# DeepSeek (OpenAI-API-compatible). Enables the live narrative commentary.
DEEPSEEK_API_KEY=

# Neo4j connection (docker-compose sets these for you; override for local runs).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword
